[Unit]
Description=eGalax UT Serial Touchscreen (inputattach)
After=systemd-udevd.service
Requires=systemd-udevd.service

[Service]
Type=simple
ExecStartPre=/sbin/modprobe egalax_ts_ut
ExecStartPre=/bin/sleep 2
ExecStart=/usr/bin/inputattach --always --eetiegalax --baud 9600 /dev/ttyS4
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
